[Appearance]
ColorScheme=SerikaOS
Font=JetBrains Mono Nerd Font,11,-1,5,50,0,0,0,0,0,Regular
UseFontLineChararacters=true
LineSpacing=2

[General]
Name=SerikaOS
Parent=FALLBACK/
Command=/bin/bash
TerminalColumns=120
TerminalRows=36
TerminalMargin=8

[Interaction Options]
AutoCopySelectedText=true
TrimLeadingSpacesInSelectedText=true
TrimTrailingSpacesInSelectedText=true
UnderlineLinksEnabled=true

[Scrolling]
HistoryMode=2
ScrollBarPosition=2

[Terminal Features]
BlinkingCursorEnabled=true
